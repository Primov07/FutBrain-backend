
# Конфигурация на базата данни (Database Configuration)

# Платформа: MongoDB Atlas
# Линк: https://www.mongodb.com/atlas
# Инструкции: Създай клъстер, кликни на "Connect", избери "Drivers" и копирай стринг-а за връзка (connection string).
# Замени <username> и <password> с потребителското име и паролата за твоята база данни.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>.mongodb.net/<dbname>?appName=<appname>

# Конфигурация на сървъра (Server Configuration)

# Портът, на който ще работи твоят бекенд сървър.
PORT=3000

# URL адресът, на който се хоства твоят фронтенд. 
# Стандартният локален URL за разработка с Vite обикновено е http://localhost:5173.
VITE_FRONTEND_URL=http://localhost:5173

# Сигурност и криптиране (Security & Encryption)

# Използва се за подписване на JWT (JSON Web Tokens) или сесийни бисквитки.
# Генерирай силен, случаен криптографски низ за продукционна среда.
SECRET_KEY=твоят_случайно_генериран_таен_ключ

# Имейл конфигурация (Nodemailer / SMTP)

# Платформа: Google Account (App Passwords / Пароли за приложения)
# Линк: https://myaccount.google.com/apppasswords
# Инструкции: Ако използваш Gmail, трябва да активираш потвърждението в две стъпки (2-Step Verification) и да генерираш 16-символна парола за приложение (App Password). Не използвай стандартната си парола за имейл.
EMAIL_USER=твоят_имейл@gmail.com
EMAIL_PASS=твоята_16_символна_парола_за_приложение

# AI Интеграции

# Платформа: Google AI Studio
# Линк: https://aistudio.google.com/app/apikey
# Инструкции: Кликни на "Create API Key", за да вземеш своя Gemini API ключ.
GEMINI_API_KEY=твоят_gemini_api_ключ_тук

# Настройки на администратора по подразбиране (Default Admin Setup)

# Данни, които се използват за създаване на първоначалния администраторски акаунт в базата данни.
ADMIN_USERNAME=administrator
ADMIN_EMAIL=admin@твоятдомейн.com
ADMIN_PASSWORD=твоята_сигурна_админ_парола
